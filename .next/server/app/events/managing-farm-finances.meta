{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/events/layout,_N_T_/events/[slug]/layout,_N_T_/events/[slug]/page,_N_T_/events/managing-farm-finances"
  },
